          flexDirection: "column",
          justifyContent: "space-between",
        }}
      >
        <div>
          <DataReadout
            label="System Status"
            value={`OBSCURATION: ACTIVE\nREVELATION: PENDING\nFRAMEWORK: PEIRCEAN TRIAD`}
          />
          <DataReadout
            label="Methodology"
            value="A brand is not a logo; it is a sign functioning within an interpretive structure."
          />
        </div>
        <div
          style={{
            display: "flex",
            flexDirection: "column",
            gap: 12,
          }}
        >
          {[
            { title: "Icon", desc: "Form, topology, visual mimicry." },
            { title: "Index", desc: "Evidence, trace, implication." },
            { title: "Symbol", desc: "Convention, cultivated meaning." },
          ].map((item) => (
            <div
              key={item.title}
              style={{
                border: "1px solid #1a1a1e",
