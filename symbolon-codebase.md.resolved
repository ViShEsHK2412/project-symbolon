        gridTemplateColumns: "60px 1fr 240px",
        fontFamily: MONO,
        color: "#6b6c70",
      }}
    >
      {/* Spine Column */}
      <div
        style={{
          borderRight: "1px solid #1a1a1e",
          display: "flex",
          flexDirection: "column",
          alignItems: "center",
          justifyContent: "space-between",
          padding: "40px 0",
          backgroundColor: "#0a0a0c",
        }}
      >
        <div
          style={{
            width: 28,
            height: 28,
            border: "1px solid #3a3a3e",
            borderRadius: "50% 0 50% 50%",
            display: "flex",
            justifyContent: "center",
            alignItems: "center",
            fontFamily: SERIF,
            fontStyle: "italic",
            fontSize: 14,
            color: "#c9a881",
          }}
        >
          S
        </div>
        <div
          style={{
            writingMode: "vertical-rl",
            transform: "rotate(180deg)",
            fontSize: 9,
            letterSpacing: "0.3em",
            textTransform: "uppercase",
            color: "#3a3a3e",
          }}
        >
          SYMBOLON IDENTITY ARCH.
        </div>
      </div>

      {/* Center Stage */}
      <div
        style={{
          display: "flex",
          flexDirection: "column",
          justifyContent: "center",
          alignItems: "center",
          padding: "80px 40px",
          position: "relative",
        }}
      >
        {/* Navigation Meta */}
        <div
          style={{
            position: "absolute",
            top: 40,
