## SymbolonFooter.tsx

```tsx
import { memo, useCallback, useRef } from "react";

const MONO = "'JetBrains Mono', 'SF Mono', 'Cascadia Code', monospace";
const SERIF = "'Cormorant Garamond', 'Playfair Display', Georgia, serif";

interface DataReadoutProps {
  readonly label: string;
  readonly value: string;
}

const DataReadout = memo(function DataReadout({
  label,
  value,
}: DataReadoutProps): JSX.Element {
  return (
    <div style={{ marginBottom: 24 }}>
      <div
        style={{
          fontFamily: MONO,
          fontSize: 9,
          letterSpacing: "0.15em",
          color: "#4a4a50",
          textTransform: "uppercase",
          borderBottom: "1px solid #1a1a1e",
          paddingBottom: 4,
          marginBottom: 8,
        }}
      >
        {label}
      </div>
      <div
        style={{
          fontFamily: MONO,
          fontSize: 11,
          color: "#8a7a65",
          lineHeight: 1.7,
          letterSpacing: "0.04em",
          whiteSpace: "pre-line",
        }}
      >
        {value}
      </div>
    </div>
  );
});

const TITLE_LETTERS = "SYMBOLON".split("");

export const SymbolonFooter = memo(function SymbolonFooter(): JSX.Element {
  const titleRef = useRef<HTMLHeadingElement>(null);

  const handleMouseEnter = useCallback(() => {
    const el = titleRef.current;
    if (el) el.style.backgroundPosition = "0 0";
  }, []);

  const handleMouseLeave = useCallback(() => {
    const el = titleRef.current;
    if (el) el.style.backgroundPosition = "100% 0";
  }, []);

  return (
    <footer
      style={{
        position: "relative",
        zIndex: 20,
        width: "100%",
        minHeight: "100vh",
        backgroundColor: "#050505",
        borderTop: "1px solid #1a1a1e",
