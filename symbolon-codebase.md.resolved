            userSelect: "none",
          }}
        >
          {TITLE_LETTERS.map((letter, i) => (
            <span key={i}>{letter}</span>
          ))}
        </h1>

        <div
          style={{
            fontFamily: SERIF,
            fontSize: 14,
            letterSpacing: "0.4em",
            color: "#4a4a50",
            textTransform: "uppercase",
          }}
        >
          The Advantage of Mystery in Semiotic Design
        </div>
      </div>

      {/* Data Panel */}
      <div
        style={{
          borderLeft: "1px solid #1a1a1e",
