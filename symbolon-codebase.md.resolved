                  color: "#c9a881",
                  marginBottom: 4,
                }}
              >
                {item.title}
              </div>
              <div style={{ fontFamily: MONO, fontSize: 9, color: "#4a4a50" }}>
                {item.desc}
              </div>
            </div>
          ))}
        </div>
      </div>
    </footer>
  );
});
