              "linear-gradient(90deg, #d97736 0%, #f2c083 50%, #c9a881 50.01%, #8a7a65 100%)",
            backgroundSize: "200% 100%",
            backgroundPosition: "100% 0",
            WebkitBackgroundClip: "text",
