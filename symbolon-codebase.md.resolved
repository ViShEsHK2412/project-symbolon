                }}
              >
                {link}
              </span>
            ))}
          </div>
          <span
            style={{
              fontSize: 10,
              letterSpacing: "0.1em",
              color: "#4a4a50",
            }}
          >
            TRGT: 0.000, 0.000
          </span>
        </div>

        {/* Hero Title */}
        <h1
          ref={titleRef}
          onMouseEnter={handleMouseEnter}
          onMouseLeave={handleMouseLeave}
          style={{
            fontFamily: SERIF,
            fontSize: "clamp(3rem, 7vw, 7.5rem)",
            fontWeight: 300,
            letterSpacing: "0.5em",
