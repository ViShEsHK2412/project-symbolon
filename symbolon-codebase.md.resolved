## App.tsx

```tsx
import { useState, useCallback } from "react";
import { MagmaCanvas } from "./components/MagmaCanvas";
import { LuxuryGrain } from "./components/LuxuryGrain";
import { SymbolonFooter } from "./components/SymbolonFooter";
import { Preloader } from "./components/Preloader";

export function App(): JSX.Element {
  const [isBooted, setIsBooted] = useState(false);

  const handleBootComplete = useCallback(() => {
    setIsBooted(true);
  }, []);

  return (
    <div
      style={{
        width: "100%",
        minHeight: "100vh",
        backgroundColor: "#000000",
        overflowX: "hidden",
        overflowY: isBooted ? "auto" : "hidden",
      }}
    >
      {!isBooted && <Preloader onComplete={handleBootComplete} />}

      {/* Z:0 — Plasma Base Layer */}
      <MagmaCanvas />

      {/* Z:10 — Analog Film Grain */}
      <LuxuryGrain />

      {/* Z:20 — Content */}
      <div style={{ position: "relative", zIndex: 20 }}>
        <SymbolonFooter />
      </div>
    </div>
  );
}

export default App;
```
