## Preloader.tsx

```tsx
import { useEffect, useRef, useCallback, memo } from "react";
import gsap from "gsap";

interface PreloaderProps {
  readonly onComplete: () => void;
}

const MONO = "'JetBrains Mono', 'SF Mono', monospace";

const STATUS_LINES: readonly string[] = [
  "INIT: SYMBOLON CORE v4.2.1",
  "LOAD: SEMIOTIC ENGINE",
  "PARSE: PEIRCEAN TRIAD SCHEMA",
  "BIND: VISUAL CORTEX PIPELINE",
  "SCAN: TOPOLOGY MESH",
  "LINK: OBSCURATION PROTOCOL",
  "SYNC: REVELATION MATRIX",
  "EXEC: IDENTITY ARCHITECTURE",
  "MOUNT: FRACTAL NOISE LAYER",
  "FUSE: AMBER PLASMA CORE",
  "SEAL: VOID BOUNDARY",
  "BOOT: COMPLETE — ENTERING VOID",
] as const;

export const Preloader = memo(function Preloader({
  onComplete,
}: PreloaderProps): JSX.Element {
  const wrapperRef = useRef<HTMLDivElement>(null);
  const counterRef = useRef<HTMLDivElement>(null);
  const statusRef = useRef<HTMLDivElement>(null);
  const completedRef = useRef(false);

  const finish = useCallback(() => {
    if (completedRef.current) return;
    completedRef.current = true;

    gsap.to(wrapperRef.current, {
      opacity: 0,
      duration: 1.2,
      ease: "power2.inOut",
      onComplete,
    });
  }, [onComplete]);

  useEffect(() => {
    const counter = { value: 0 };
    let statusIndex = 0;
    const statusInterval = (4500 - 1200) / STATUS_LINES.length;

    const statusTimer = setInterval(() => {
      if (statusRef.current && statusIndex < STATUS_LINES.length) {
        const line = document.createElement("div");
        line.textContent = `> ${STATUS_LINES[statusIndex]}`;
        line.style.opacity = "0";
        statusRef.current.appendChild(line);
        gsap.to(line, { opacity: 1, duration: 0.15, ease: "none" });
        statusRef.current.scrollTop = statusRef.current.scrollHeight;
        statusIndex++;
      }
    }, statusInterval);

    const tl = gsap.timeline({ onComplete: finish });

    tl.to(counter, {
      value: 100,
      duration: 4.5,
      ease: "power1.inOut",
      onUpdate: () => {
        if (counterRef.current) {
          counterRef.current.textContent = `${Math.floor(counter.value)}`;
        }
      },
    });

    return () => {
      clearInterval(statusTimer);
      tl.kill();
    };
  }, [finish]);

  return (
    <div
      ref={wrapperRef}
      style={{
        position: "fixed",
        inset: 0,
        zIndex: 9999,
        backgroundColor: "#000000",
        display: "flex",
        flexDirection: "column",
        justifyContent: "center",
        alignItems: "center",
        fontFamily: MONO,
        color: "#d97736",
        gap: 40,
      }}
    >
      {/* Counter */}
      <div
        ref={counterRef}
        style={{
          fontSize: "clamp(4rem, 12vw, 10rem)",
          fontWeight: 100,
          letterSpacing: "-0.02em",
          lineHeight: 1,
          color: "#c9a881",
          opacity: 0.9,
        }}
      >
        0
      </div>

      {/* Status Console */}
      <div
        ref={statusRef}
        style={{
          width: "min(500px, 80vw)",
          height: 180,
          overflowY: "hidden",
          fontSize: 10,
          lineHeight: 1.8,
          letterSpacing: "0.06em",
          color: "#4a4a50",
          textTransform: "uppercase",
        }}
      />

      {/* Bottom Label */}
      <div
        style={{
          position: "absolute",
          bottom: 40,
          fontSize: 9,
          letterSpacing: "0.3em",
          textTransform: "uppercase",
          color: "#2a2a2e",
        }}
      >
        SYMBOLON IDENTITY ARCHITECTURE
      </div>
    </div>
  );
});

export default Preloader;
```

