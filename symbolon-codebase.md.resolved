## LuxuryGrain.tsx

```tsx
import { memo } from "react";

const GRAIN_KEYFRAMES = `
@keyframes luxGrainFlicker {
  0%, 100% { transform: translate(0, 0); }
  10% { transform: translate(-1%, -1%); }
  20% { transform: translate(-2%, 1%); }
  30% { transform: translate(1%, -2%); }
  40% { transform: translate(-1%, 2%); }
  50% { transform: translate(-2%, -1%); }
  60% { transform: translate(2%, 1%); }
  70% { transform: translate(1%, 2%); }
  80% { transform: translate(-1%, -1%); }
  90% { transform: translate(2%, -2%); }
}
`;

const NOISE_SVG =
  "data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E";

export const LuxuryGrain = memo(function LuxuryGrain(): JSX.Element {
  return (
    <>
      <style>{GRAIN_KEYFRAMES}</style>
      <div
        aria-hidden="true"
        style={{
          position: "fixed",
          inset: 0,
          width: "100vw",
          height: "100vh",
          zIndex: 10,
          pointerEvents: "none",
          mixBlendMode: "soft-light",
          opacity: 0.04,
          backgroundImage: `url("${NOISE_SVG}")`,
          backgroundRepeat: "repeat",
          animation: "luxGrainFlicker 0.15s steps(8) infinite",
          willChange: "transform",
        }}
      />
    </>
  );
});
